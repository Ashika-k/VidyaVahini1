<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available Bus Routes"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/purpleDark"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnArsikere"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hassan → Arsikere"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/purplePrimary"
            android:textColor="@android:color/white"/>

        <Button
            android:id="@+id/btnBelur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hassan → Belur"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/purplePrimary"
            android:textColor="@android:color/white"/>

        <Button
            android:id="@+id/btnSakleshpur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hassan → Sakleshpur"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/purplePrimary"
            android:textColor="@android:color/white"/>
        <Button
            android:id="@+id/btnChannarayapatna"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hassan → Channarayapatna"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/purplePrimary"
            android:textColor="@android:color/white"/>

        <Button
            android:id="@+id/btnHolenarasipura"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hassan → Holenarasipura"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/purplePrimary"
            android:textColor="@android:color/white"/>

        <Button
            android:id="@+id/btnAlur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hassan → Alur"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/purplePrimary"
            android:textColor="@android:color/white"/>

        <Button
            android:id="@+id/btnYeslur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hassan → Yeslur"
            android:textAllCaps="false"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/purplePrimary"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</ScrollView>